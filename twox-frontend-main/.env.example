# =============================================================================
# TwoX player frontend (Next.js) — copy to .env.local and adjust.
# =============================================================================

# -----------------------------------------------------------------------------
# Option A — Direct API (simplest local & many deployments)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BACKEND_API=http://localhost:5000/api
# Canonical site URL (SSR, links). Local dev optional; set on Vercel to your domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Socket.IO connects to the backend origin (no /api). Usually inferred from NEXT_PUBLIC_BACKEND_API.
# Set explicitly if the socket server differs from the REST API host:
# NEXT_PUBLIC_BACKEND_ORIGIN=http://localhost:5000

# -----------------------------------------------------------------------------
# Option B — Same-origin API proxy (avoids CORS / mixed-content for REST)
# Set NEXT_PUBLIC_USE_API_PROXY=1 and BACKEND_PROXY_TARGET. REST uses /_api → backend.
# At build time, BACKEND_PROXY_TARGET is copied to NEXT_PUBLIC_BACKEND_PROXY_TARGET for Socket.IO.
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_USE_API_PROXY=1
# BACKEND_PROXY_TARGET=http://127.0.0.1:5000/api
# Optional override if the public proxy target must differ from BACKEND_PROXY_TARGET:
# NEXT_PUBLIC_BACKEND_PROXY_TARGET=https://api.yourdomain.com/api

# Production (Vercel): set in Project → Settings → Environment Variables (all envs that build the app):
#   - Either NEXT_PUBLIC_BACKEND_API=https://your-api.com/api
#   - Or NEXT_PUBLIC_USE_API_PROXY=1 + BACKEND_PROXY_TARGET=https://your-api.com/api
#   - NEXT_PUBLIC_SITE_URL=https://your-player-app.vercel.app (or custom domain)
# If you use the proxy and sockets: BACKEND_PROXY_TARGET must be set at build time so the client
# bundle knows the real socket origin (or set NEXT_PUBLIC_BACKEND_ORIGIN / NEXT_PUBLIC_BACKEND_API).

# -----------------------------------------------------------------------------
# Other
# -----------------------------------------------------------------------------
# Fystack-aligned UI only (no secrets). Backend FYSTACK_* drives real custody.
NEXT_PUBLIC_FYSTACK_UI_STABLECOINS_ONLY=

# Payment debug: POST traces when backend enables trace ingest.
NEXT_PUBLIC_DEBUG_PAYMENT_TRACE=false
# Optional: NEXT_PUBLIC_PAYMENT_TRACE_INGEST_URL=

NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
NEXT_PUBLIC_FINGERPRINT_API_KEY=
NEXT_PUBLIC_FINGERPRINT_REGION=eu

NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=

NEXT_PUBLIC_INFURA_ID=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

ANALYZE=false
